# Redirección de NO www a WWW y Forzar HTTPS
RewriteEngine On

# 1. Redirigir el dominio sin www a la versión con www
RewriteCond %{HTTP_HOST} ^jordiexposito\.com$ [NC]
RewriteRule ^(.*)$ https://www.jordiexposito.com/$1 [R=301,L]

# 2. Forzar HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
